{
  "$meta": {
    "name": "Groundwork Web UI Design Tokens",
    "version": "1.0.0",
    "themes": ["light", "dark"],
    "note": "Consumed by the static Vite SPA (go:embed). Mirrors tokens/groundwork-ui.css. All component styling references these; the two themes track one source of truth."
  },
  "font": {
    "ui": "Inter, system-ui, -apple-system, sans-serif",
    "mono": "IBM Plex Mono, ui-monospace, Menlo, monospace"
  },
  "radius": { "sm": "5px", "md": "8px" },
  "space": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px" },
  "motion": {
    "ease": "cubic-bezier(.2,0,0,1)",
    "easeIn": "cubic-bezier(.16,1,.3,1)",
    "durFast": "140ms", "durBase": "220ms", "durSlow": "420ms"
  },
  "color": {
    "light": {
      "bg": "#F4F2EE", "surface": "#FFFFFF", "surface2": "#F6F4F0", "surface3": "#EDEAE3",
      "shell": "#1E1F21", "shell2": "#292A2C", "shellBorder": "#34363A",
      "fg": "#1E1F21", "fgMuted": "#6B6F76", "fgSubtle": "#8A8D93",
      "onShell": "#E9E5DC", "onShellMuted": "#9A9CA1",
      "border": "#E5E2DB", "border2": "#D6D2C8",
      "accent": "#6B1D1F", "accent2": "#4A1416", "accentTint": "#F4EAEA", "accentLine": "#9c4b3b", "focus": "#6B1D1F", "onAccent": "#F3F0E8",
      "ok": "#2F8055", "okBg": "#E9F3EC", "okBd": "#C6E2D0",
      "warn": "#946400", "warnBg": "#FBF2D9", "warnBd": "#ECDBA0",
      "bad": "#B23A2C", "badBg": "#FAE9E6", "badBd": "#F0CDC4",
      "run": "#3A6EA5", "runBg": "#EAF1F8", "runBd": "#CBDDEF",
      "idle": "#6B6F76", "idleBg": "#F0EEE9", "idleBd": "#DCD7CD",
      "human": "#6B6F76", "ai": "#516579", "judge": "#946400", "provBg": "#FBF4EC"
    },
    "dark": {
      "bg": "#16171A", "surface": "#1E1F22", "surface2": "#24262A", "surface3": "#2B2D31",
      "shell": "#101113", "shell2": "#1C1D20", "shellBorder": "#303236",
      "fg": "#E9E5DC", "fgMuted": "#A6A29A", "fgSubtle": "#7C7A74",
      "onShell": "#E9E5DC", "onShellMuted": "#8C8E93",
      "border": "#2C2E32", "border2": "#3A3D42",
      "accent": "#6B1D1F", "accent2": "#7E2A2B", "accentTint": "rgba(199,122,107,.14)", "accentLine": "#C77A6B", "focus": "#C77A6B", "onAccent": "#F3F0E8",
      "ok": "#64BE8B", "okBg": "rgba(47,128,85,.16)", "okBd": "rgba(100,190,139,.30)",
      "warn": "#D6A94A", "warnBg": "rgba(148,100,0,.20)", "warnBd": "rgba(214,169,74,.32)",
      "bad": "#E27E6E", "badBg": "rgba(178,58,44,.20)", "badBd": "rgba(226,126,110,.34)",
      "run": "#6F9FD6", "runBg": "rgba(58,110,165,.20)", "runBd": "rgba(111,159,214,.32)",
      "idle": "#93969C", "idleBg": "rgba(255,255,255,.05)", "idleBd": "rgba(255,255,255,.12)",
      "human": "#A6A29A", "ai": "#7C97AE", "judge": "#D6A94A", "provBg": "rgba(199,122,107,.06)"
    }
  },
  "elevation": {
    "light": {
      "sh1": "0 1px 2px rgba(30,31,33,.05)",
      "sh2": "0 1px 2px rgba(30,31,33,.06), 0 6px 18px -8px rgba(30,31,33,.14)",
      "sh3": "0 8px 20px -6px rgba(30,31,33,.12), 0 24px 48px -18px rgba(30,31,33,.22)"
    },
    "dark": {
      "sh1": "0 1px 2px rgba(0,0,0,.30)",
      "sh2": "0 1px 2px rgba(0,0,0,.30), 0 6px 18px -8px rgba(0,0,0,.55)",
      "sh3": "0 8px 20px -6px rgba(0,0,0,.45), 0 24px 48px -18px rgba(0,0,0,.65)"
    }
  }
}
