<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Groundwork — Dashboard</title>
<link rel="icon" href="data:,">
<link rel="stylesheet" href="/static/groundwork.css">
</head>
<body>
<div class="gw-app">

  <aside class="gw-side">
    <div class="gw-brand">
      <b>Groundwork</b>
      <div class="repo">{{.Repo}} · <span class="branch">{{.Branch}}</span></div>
    </div>
    <nav class="gw-nav">
      <div class="group">Operate</div>
      <a class="active" href="/"><span class="dot"></span> Dashboard</a>
      <a class="soon"><span class="dot"></span> Board <span class="pill">soon</span></a>
      <a class="soon"><span class="dot"></span> Tickets <span class="pill">soon</span></a>
      <a class="soon"><span class="dot"></span> Runs <span class="pill">soon</span></a>
      <a class="soon"><span class="dot"></span> Approvals{{if .PendingApprovals}} <span class="pill">{{.PendingApprovals}}</span>{{else}} <span class="pill">soon</span>{{end}}</a>
      <div class="group">Configure</div>
      <a class="soon"><span class="dot"></span> Policies <span class="pill">soon</span></a>
      <a class="soon"><span class="dot"></span> Settings <span class="pill">soon</span></a>
    </nav>
    <div class="gw-side-foot">
      <div class="row"><span>server</span><b>{{.ServerAddr}}</b></div>
      <div class="row"><span>state.sqlite</span><b>{{.DBSize}}</b></div>
      <div class="row"><span>gw</span><b>{{.Version}}</b></div>
    </div>
  </aside>

  <main class="gw-main">
    <header class="gw-top">
      <div class="gw-crumb">Operate / <b>Dashboard</b></div>
      <div class="gw-spacer"></div>
      <div class="gw-live" id="live"><span class="bdot"></span> <span id="live-label">connecting…</span></div>
    </header>

    <div class="gw-content">

      <div class="gw-kpis">
        {{range .KPIs}}
        <div class="gw-kpi {{.Tone}}">
          <div class="label">{{.Label}}</div>
          <div class="value">{{.Value}}</div>
          {{if .Sub}}<div class="sub">{{.Sub}}</div>{{end}}
        </div>
        {{end}}
      </div>

      <div class="gw-panel">
        <div class="gw-panel-head">
          <h3>Active runs</h3>
          {{if .Runs}}<span class="gw-badge run"><i class="bdot"></i>{{len .Runs}} live</span>{{end}}
          <span class="gw-id">{{.Now}}</span>
        </div>
        {{if .Runs}}
        <table class="gw-table">
          <thead><tr><th>Work</th><th>Actor</th><th>Mode</th><th>Status</th><th>Elapsed</th><th>Last event</th></tr></thead>
          <tbody>
            {{range .Runs}}
            <tr>
              <td><div class="gw-cell-title">{{.Title}}</div><div class="gw-id">{{.Ticket}} · {{.RunID}}</div></td>
              <td class="gw-muted">{{.Actor}}</td>
              <td class="gw-muted">{{.Mode}}</td>
              <td><span class="gw-badge {{.Tone}}"><i class="bdot"></i>{{.Status}}</span></td>
              <td class="num">{{.Elapsed}}</td>
              <td class="gw-subtle">{{.Last}}</td>
            </tr>
            {{end}}
          </tbody>
        </table>
        {{else}}
        <div class="gw-empty">No active runs. The scheduler dispatches eligible work when the trust policy authorizes an actor (ADR 0033).</div>
        {{end}}
      </div>

      <div class="gw-cols">
        <div class="gw-panel">
          <div class="gw-panel-head"><h3>Attention queue</h3><span class="gw-id">{{len .Attention}} items</span></div>
          <div class="gw-panel-body">
            {{if .Attention}}
            <div class="gw-attn">
              {{range .Attention}}
              <div class="gw-attn-item">
                <span class="gw-badge {{.Tone}} tag"><i class="bdot"></i>{{.Tag}}</span>
                <div class="body"><div class="title">{{.Title}}</div><div class="meta">{{.Meta}}</div></div>
              </div>
              {{end}}
            </div>
            {{else}}
            <div class="gw-empty">Nothing needs attention — no pending approvals or blocked work.</div>
            {{end}}
          </div>
        </div>

        <div class="gw-panel">
          <div class="gw-panel-head"><h3>Recent events</h3><span class="gw-id">audit log</span></div>
          <div class="gw-panel-body">
            {{if .Events}}
            <div class="gw-tl">
              {{range .Events}}
              <div class="gw-tl-item">
                <div class="gw-tl-time">{{.Time}}</div>
                <div class="gw-tl-body"><span class="ev">{{.Event}}</span> <span class="obj">{{.Object}}</span><div class="who">{{.Who}}</div></div>
              </div>
              {{end}}
            </div>
            {{else}}
            <div class="gw-empty">No events recorded yet.</div>
            {{end}}
          </div>
        </div>
      </div>

      <div class="gw-cols-3">
        <div class="gw-panel">
          <div class="gw-panel-head"><h3>Work tree</h3></div>
          <div class="gw-panel-body">
            {{range .StatusBreakdown}}
            <div class="gw-between"><span class="gw-muted">{{.Status}}</span><span class="num">{{.Count}}</span></div>
            {{end}}
          </div>
        </div>
        <div class="gw-panel">
          <div class="gw-panel-head"><h3>Local runtime</h3></div>
          <div class="gw-panel-body">
            <div class="gw-between"><span class="gw-muted">runtime</span><span class="mono">{{.Runtime}}</span></div>
            <div class="gw-between"><span class="gw-muted">sandbox</span><span class="gw-badge ok"><i class="bdot"></i>{{.Sandbox}}</span></div>
            <div class="gw-between"><span class="gw-muted">max concurrency</span><span class="num">{{.Concurrency}}</span></div>
            <div class="gw-between"><span class="gw-muted">uptime</span><span class="mono">{{.Uptime}}</span></div>
            <div class="gw-between"><span class="gw-muted">state.sqlite</span><span class="mono">{{.DBSize}}</span></div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<script>
// Realtime: a lightweight live/heartbeat indicator over SSE, plus a soft refresh
// so the server-rendered page stays current without a client framework (v1).
(function () {
  var live = document.getElementById("live");
  var label = document.getElementById("live-label");
  var reloadTimer = null;
  function softReload() {
    if (reloadTimer) return;
    reloadTimer = setTimeout(function () { location.reload(); }, 1200);
  }
  try {
    var es = new EventSource("/api/v1/events");
    es.onopen = function () { live.classList.add("on"); label.textContent = "live"; };
    es.onerror = function () { live.classList.remove("on"); label.textContent = "reconnecting…"; };
    es.onmessage = function (e) { if (e.data && e.data.indexOf("heartbeat") === -1) softReload(); };
  } catch (err) {
    label.textContent = "offline";
  }
  // Fallback periodic refresh (operational monitor) when the tab is visible.
  setInterval(function () { if (!document.hidden) location.reload(); }, 20000);
})();
</script>
</body>
</html>
